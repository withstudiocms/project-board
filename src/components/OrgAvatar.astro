---
import { fetchOrganization } from "../lib/github";
import { config } from "../config";

const org = config.organization;

// Fetch organization details for avatar
const orgData = await fetchOrganization(org);

const avatarUrl = orgData?.avatar_url;
---

{
    avatarUrl && (
        <img src={avatarUrl} alt="Organization avatar" class="org-avatar" />
    )
}
